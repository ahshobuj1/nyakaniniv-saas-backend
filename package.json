{
    "name": "express-backend-template",
    "module": "index.ts",
    "type": "module",
    "scripts": {
        "dev": "NODE_ENV=development bun run --watch src/index.ts",
        "build": "NODE_ENV=production bun build src/index.ts --target node --outdir dist",
        "start": "NODE_ENV=production bun run dist/index.js",
        "test": "NODE_ENV=test bun test",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:migrate:prod": "prisma migrate deploy",
        "db:reset": "prisma migrate reset",
        "db:seed": "bun run prisma/seed.ts",
        "db:studio": "prisma studio",
        "db:push": "prisma db push",
        "setup": "bun install && bun run db:generate && bun run db:migrate",
        "reset": "bun run db:reset && bun run db:seed",
        "clean": "rm -rf dist node_modules .next",
        "type-check": "tsc --noEmit",
        "lint": "eslint src --ext .ts,.tsx",
        "lint:fix": "eslint src --ext .ts,.tsx --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
        "docker:up": "docker-compose up -d",
        "docker:down": "docker-compose down",
        "docker:logs": "docker-compose logs -f",
        "add:module": "bun scripts/generate-module.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1050.0",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.2.0",
        "axios": "^1.12.2",
        "bcrypt": "^6.0.0",
        "bcryptjs": "^3.0.3",
        "chalk": "^5.6.0",
        "cloudinary": "^2.10.0",
        "compression": "^1.8.1",
        "connect-timeout": "^1.9.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "date-fns": "^4.1.0",
        "dotenv": "^17.2.3",
        "express": "^5.1.0",
        "express-rate-limit": "^8.0.1",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "lodash": "^4.17.21",
        "multer": "^2.0.2",
        "pg": "^8.16.3",
        "prisma": "^7.2.0",
        "stripe": "^22.1.1",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "uuid": "^14.0.0",
        "winston": "^3.17.0",
        "winston-daily-rotate-file": "^5.0.0",
        "zod": "^4.1.1"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/bun": "latest",
        "@types/compression": "^1.8.1",
        "@types/connect-timeout": "^1.9.0",
        "@types/cookie-parser": "^1.4.9",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/lodash": "^4.17.20",
        "@types/multer": "^2.0.0",
        "@types/node": "^25.0.3",
        "@types/pg": "^8.16.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
